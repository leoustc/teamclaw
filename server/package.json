{
  "name": "@teamclawai/server",
  "version": "0.3.0",
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "files": [
    "dist",
    "ui-dist",
    "skills"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:watch": "cross-env TEAMCLAW_MIGRATION_PROMPT=never tsx watch --ignore ../ui/node_modules --ignore ../ui/.vite --ignore ../ui/dist src/index.ts",
    "prepare:ui-dist": "bash ../scripts/prepare-server-ui-dist.sh",
    "build": "tsc",
    "prepack": "pnpm run prepare:ui-dist",
    "postpack": "rm -rf ui-dist",
    "clean": "rm -rf dist",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.888.0",
    "@teamclawai/adapter-claude-local": "workspace:*",
    "@teamclawai/adapter-codex-local": "workspace:*",
    "@teamclawai/adapter-cursor-local": "workspace:*",
    "@teamclawai/adapter-oca-local": "workspace:*",
    "@teamclawai/adapter-opencode-local": "workspace:*",
    "@teamclawai/adapter-pi-local": "workspace:*",
    "@teamclawai/adapter-openclaw-gateway": "workspace:*",
    "@teamclawai/adapter-utils": "workspace:*",
    "@teamclawai/db": "workspace:*",
    "@teamclawai/shared": "workspace:*",
    "better-auth": "1.4.18",
    "detect-port": "^2.1.0",
    "dotenv": "^17.0.1",
    "drizzle-orm": "^0.38.4",
    "embedded-postgres": "^18.1.0-beta.16",
    "express": "^5.1.0",
    "multer": "^2.0.2",
    "open": "^11.0.0",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "pino-pretty": "^13.1.3",
    "ws": "^8.19.0",
    "zod": "^3.24.2"
  },
  "optionalDependencies": {
    "authenticate-pam": "^1.0.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/express-serve-static-core": "^5.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.6.0",
    "@types/supertest": "^6.0.2",
    "@types/ws": "^8.18.1",
    "cross-env": "^10.1.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.1.0",
    "vitest": "^3.0.5"
  }
}
